{
    "name": "hyperized/file",
    "description": "Declarative POSIX file and directory state for PHP.",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Gerben Geijteman",
            "email": "gerben@hyperized.net"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-posix": "*"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.52",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "Hyperized\\File\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hyperized\\File\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        },
        "platform": {
            "php": "8.3.0"
        },
        "sort-packages": true
    },
    "scripts": {
        "coverage": "vendor/bin/pest --coverage",
        "integration": "vendor/bin/pest --testsuite=integration",
        "pest": "vendor/bin/pest",
        "phpstan": "vendor/bin/phpstan analyse",
        "test": [
            "@phpstan",
            "@pest"
        ]
    }
}
